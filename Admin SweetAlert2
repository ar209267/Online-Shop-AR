<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Online Shop AR - Admin & User Panel</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@400;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <style>
        :root {
            --bg-dark: #0b0e14;
            --panel-dark: #161b22;
            --primary-blue: #58a6ff;
            --success-green: #238636;
            --text-gray: #8b949e;
        }

        body {
            background-color: var(--bg-dark);
            color: #f0f6fc;
            font-family: 'Hind Siliguri', sans-serif;
            margin: 0;
            padding-bottom: 50px;
        }

        /* Navbar Customization */
        .navbar {
            background-color: var(--panel-dark);
            border-bottom: 2px solid var(--primary-blue);
            padding: 15px 0;
        }
        .navbar-brand { color: var(--primary-blue) !important; font-weight: 700; font-size: 24px; }

        /* General UI Elements */
        .glass-panel {
            background-color: var(--panel-dark);
            padding: 25px;
            border-radius: 12px;
            border: 1px solid #30363d;
            margin-top: 20px;
        }
        .section-title {
            margin: 40px 0 20px;
            border-left: 5px solid var(--primary-blue);
            padding-left: 15px;
            font-weight: 700;
        }

        /* Admin & User View Control */
        #adminView { display: none; }
        .admin-badge {
            background: #f85149;
            color: white;
            padding: 2px 8px;
            border-radius: 5px;
            font-size: 12px;
            margin-left: 10px;
        }

        /* Table Styling */
        .custom-table {
            background-color: var(--panel-dark);
            color: white;
            border-radius: 10px;
            overflow: hidden;
        }
        .status-badge {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
        }
        .pending { background: rgba(210, 153, 34, 0.2); color: #d29922; }

        .btn-admin-login {
            background: transparent;
            border: 1px solid #30363d;
            color: var(--text-gray);
            font-size: 12px;
            transition: 0.3s;
        }
        .btn-admin-login:hover { color: white; border-color: var(--primary-blue); }
    </style>
</head>
<body>

    <nav class="navbar navbar-dark">
        <div class="container d-flex justify-content-between align-items-center">
            <a class="navbar-brand" href="#">ONLINE SHOP AR</a>
            <div>
                <button id="loginBtn" class="btn btn-admin-login btn-sm" onclick="AdminManager.login()">Admin Login</button>
                <button id="logoutBtn" class="btn btn-outline-danger btn-sm" style="display:none;" onclick="AdminManager.logout()">Logout</button>
            </div>
        </div>
    </nav>

    <div class="container">
        
        <div id="userView">
            <div class="glass-panel text-center">
                <h3>স্বাগতম, Atiq</h3>
                <p class="text-muted">আপনার পছন্দের গেমিং সার্ভিস সিলেক্ট করুন</p>
                <div class="display-4 fw-bold mb-3">৳ 0.00</div>
                <button class="btn btn-primary px-5">টাকা রিচার্জ করুন</button>
            </div>

            <h2 class="section-title">অর্ডার ফর্ম</h2>
            <div class="glass-panel">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">সার্ভিস বেছে নিন</label>
                        <select id="serviceType" class="form-select bg-dark text-white border-secondary">
                            <option value="FF">Free Fire Diamond</option>
                            <option value="PUBG">PUBG UC</option>
                            <option value="SMM">SMM Service</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">প্লেয়ার আইডি / লিংক</label>
                        <input type="text" id="orderTarget" class="form-control bg-dark text-white border-secondary" placeholder="ID লিখুন">
                    </div>
                </div>
                <button class="btn btn-success w-100 py-2 fw-bold" onclick="placeOrder()">অর্ডার কনফার্ম করুন</button>
            </div>
        </div>

        <div id="adminView">
            <h2 class="section-title">অ্যাডমিন ড্যাশবোর্ড <span class="admin-badge">ADMIN MODE</span></h2>
            
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="glass-panel text-center border-primary">
                        <h6>মোট অর্ডার</h6>
                        <h2 id="totalOrdersCount">0</h2>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="glass-panel text-center border-success">
                        <h6>মোট ইনকাম</h6>
                        <h2>৳ 0.00</h2>
                    </div>
                </div>
            </div>

            <h3 class="mt-5">রিসেন্ট অর্ডার লিস্ট</h3>
            <div class="table-responsive mt-3">
                <table class="table custom-table text-white">
                    <thead>
                        <tr>
                            <th>সময়</th>
                            <th>সার্ভিস</th>
                            <th>টার্গেট আইডি</th>
                            <th>স্ট্যাটাস</th>
                            <th>অ্যাকশন</th>
                        </tr>
                    </thead>
                    <tbody id="adminOrderLog">
                        </tbody>
                </table>
            </div>
        </div>

    </div>

    <script>
        // সিকিউর অ্যাডমিন ম্যানেজার
        const AdminManager = {
            // প্রফেশনাল লগইন ডিটেইলস (আপনি চাইলে পরিবর্তন করতে পারেন)
            config: {
                user: "atiq_admin",
                pass: "Admin@Atiq#2026"
            },

            async login() {
                const { value: formValues } = await Swal.fire({
                    title: 'প্রফেশনাল অ্যাডমিন লগইন',
                    background: '#161b22',
                    color: '#fff',
                    html:
                        '<input id="swal-user" class="swal2-input" style="color:white" placeholder="ইউজার আইডি">' +
                        '<input id="swal-pass" type="password" class="swal2-input" style="color:white" placeholder="পাসওয়ার্ড">',
                    focusConfirm: false,
                    confirmButtonText: 'প্রবেশ করুন',
                    confirmButtonColor: '#238636',
                    preConfirm: () => {
                        return [
                            document.getElementById('swal-user').value,
                            document.getElementById('swal-pass').value
                        ]
                    }
                });

                if (formValues) {
                    const [u, p] = formValues;
                    if (u === this.config.user && p === this.config.pass) {
                        this.launchAdmin();
                    } else {
                        Swal.fire({ icon: 'error', title: 'ভুল তথ্য!', text: 'সঠিক আইডি বা পাসওয়ার্ড দিন।' });
                    }
                }
            },

            launchAdmin() {
                sessionStorage.setItem('isAdmin', 'true');
                document.getElementById('userView').style.display = 'none';
                document.getElementById('adminView').style.display = 'block';
                document.getElementById('loginBtn').style.display = 'none';
                document.getElementById('logoutBtn').style.display = 'inline-block';
                
                Swal.fire({ icon: 'success', title: 'স্বাগতম অ্যাডমিন!', timer: 1500, showConfirmButton: false });
            },

            logout() {
                sessionStorage.removeItem('isAdmin');
                location.reload();
            }
        };

        // অর্ডার করার ফাংশন
        function placeOrder() {
            const service = document.getElementById('serviceType').value;
            const target = document.getElementById('orderTarget').value;

            if(!target) return Swal.fire('দয়া করে আইডি দিন');

            Swal.fire({
                title: 'অর্ডার জমা হচ্ছে...',
                timer: 2000,
                didOpen: () => { Swal.showLoading() }
            }).then(() => {
                // এটি সাময়িকভাবে অ্যাডমিন প্যানেলে ডাটা পাঠাবে (রিয়েল ডাটাবেসের জন্য Firebase লাগবে)
                const log = document.getElementById('adminOrderLog');
                const row = `<tr>
                    <td>${new Date().toLocaleTimeString()}</td>
                    <td>${service}</td>
                    <td>${target}</td>
                    <td><span class="status-badge pending">Pending</span></td>
                    <td><button class="btn btn-sm btn-primary">Done</button></td>
                </tr>`;
                log.innerHTML = row + log.innerHTML;
                
                Swal.fire('অর্ডার সফল!', 'আপনার অর্ডারটি অ্যাডমিন দেখছে।', 'success');
                document.getElementById('orderTarget').value = '';
            });
        }

        // পেজ লোড হলে চেক করা (Refresh দিলে লগইন থাকবে)
        window.onload = () => {
            if(sessionStorage.getItem('isAdmin') === 'true') {
                AdminManager.launchAdmin();
            }
        };
    </script>
</body>
</html>
