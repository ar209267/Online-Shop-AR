// Firebase SDK ইমপোর্ট করা
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.0.0/firebase-app.js";
import { getAuth, GithubAuthProvider, signInWithPopup } from "https://www.gstatic.com/firebasejs/10.0.0/firebase-auth.js";

// আপনার Firebase কনফিগারেশন (Project Settings থেকে কপি করে এখানে বসান)
const firebaseConfig = {
  apiKey: "YOUR_API_KEY",
  authDomain: "online-shop-ar.firebaseapp.com",
  projectId: "online-shop-ar",
  storageBucket: "online-shop-ar.appspot.com",
  messagingSenderId: "YOUR_SENDER_ID",
  appId: "YOUR_APP_ID"
};

// Firebase ইনিশিয়ালাইজ করা
const app = initializeApp(firebaseConfig);
const auth = getAuth(app);
const provider = new GithubAuthProvider();

// লগইন ফাংশন
const loginBtn = document.getElementById('github-login');

loginBtn.addEventListener('click', () => {
  signInWithPopup(auth, provider)
    .then((result) => {
      const user = result.user;
      console.log("ইউজার লগইন হয়েছে:", user);
      document.getElementById('user-info').innerHTML = `<h3>স্বাগতম, ${user.displayName}</h3>`;
    })
    .catch((error) => {
      console.error("লগইন সমস্যা:", error.message);
      alert("সমস্যা হয়েছে: " + error.message);
    });
});
